export const UpdateQuizDtoSchema = z.object({
  courseIds: z.array(z.string()).describe("IDs of the courses this quiz belongs to").optional(),
  groupIds: z.array(z.string()).describe("IDs of the courses groups this quiz belongs to (optional)").optional(),
  lectureIds: z.array(z.string()).describe("IDs of lectures this quiz belongs to (can be multiple)").optional(),
  title: z.string().describe("Quiz title").optional(),
  description: z.string().describe("Quiz description").optional(),
  language: z.enum(["en", "ar", "en_ar"]).describe("Quiz language (en, ar, or en_ar for bilingual)").optional(),
  type: z.enum(["quiz", "full_exam"]).describe("Type of exam (quiz or full_exam)").optional(),
  difficulty: z.enum(["BEGINNER", "INTERMEDIATE", "ADVANCED"]).describe("Difficulty level of the quiz").optional(),
  totalMarks: z.number().gte(1).describe("Total marks for the quiz").optional(),
  passingScore: z.number().gte(0).lte(100).describe("Passing score percentage (0-100)").optional(),
  timeLimit: z.number().gte(1).describe("Time limit in minutes").optional(),
  attemptsLimit: z.number().gte(1).default(4).describe("Maximum number of attempts allowed (default: 4)").optional(),
  showCorrectness: z.boolean().describe("Whether to show correctness immediately after answering").optional(),
  showExplanation: z.boolean().describe("Whether to show explanations after answering").optional(),
  shuffleQuestions: z.boolean().describe("Whether to randomize question order").optional(),
  shuffleOptions: z.boolean().describe("Whether to randomize option order (for MCQ)").optional(),
  isPublished: z.boolean().describe("Whether the quiz is published and available to students").optional()
});

export const MatchPairDataSchema = z.object({
  id: z.string().describe("Match ID"),
  leftText: z.string().describe("Left text for matching"),
  rightText: z.string().describe("Right text for matching")
});

export const QuestionDataSchema = z.object({
  id: z.string().describe("Question ID"),
  quizId: z.number().describe("Quiz ID that this question belongs to"),
  type: z.lazy(() => QuestionTypeSchema),
  marks: z.number().describe("Points awarded for correct answer"),
  order: z.number().describe("Display order of the question in quiz"),
  difficulty: z.enum(["BEGINNER", "INTERMEDIATE", "ADVANCED", "EXPERT"]).describe("Difficulty level of the question").optional(),
  maxAttempts: z.number().describe("Maximum attempts allowed for this question").optional(),
  partialCredit: z.boolean().describe("Whether partial credit is awarded"),
  codeLanguage: z.string().describe("Programming language for code questions").optional(),
  isActive: z.boolean().describe("Whether the question is active"),
  createdAt: z.string().describe("When the question was created"),
  updatedAt: z.string().describe("When the question was last updated"),
  expectedCorrectCount: z.number().describe("Expected number of correct options to select for MULTIPLE_ANSWER questions").optional(),
  explanation: z.string().describe("Explanation shown after answering the question").optional(),
  matches: z.array(z.lazy(() => MatchPairDataSchema)).describe("Matches for drag-and-drop questions").optional(),
  imageUrl: z.string().describe("Image URL for the question").nullable().optional(),
  text: z.string().describe("Question text").nullable().optional(),
  correctAnswer: z.record(z.unknown()).describe("Correct answer(s) for the question").nullable().optional()
});

export const QuizQuestionResponseDtoSchema = z.object({
