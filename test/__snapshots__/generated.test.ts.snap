// ========== Zod Validators ==========
export const CreateCourseDtoSchema = z.object({
  title: z.string().min(2).describe("Course title"),
  description: z.string().min(10).describe("Detailed course description"),
  thumbnail: z.string().describe("Course thumbnail image URL").optional(),
  paymentMethods: z.array(z.string()).describe("Payment methods for the course").optional(),
  certificateName: z.string().describe("Course's certificate display name").optional(),
  language: z.enum(["en", "ar"]).default("en").describe("Course language").optional(),
  langDescription: z.string().describe("Additional description in course language for international users").optional(),
  internationalExamLang: z.enum(["en", "ar", "en_ar"]).default("en_ar").describe("Preferred exam language for international students").optional(),
  priceUSD: z.number().gte(0).describe("Course price in USD"),
  priceEGP: z.number().gte(0).describe("Course price in EGP (Egyptian Pound)"),
  categoryId: z.string().describe("Category ID").optional(),
  tags: z.array(z.string()).describe("Course tags").optional(),
  targetAudience: z.array(z.string()).describe("Target audience for the course").optional(),
  learningOutcomes: z.array(z.string()).describe("Learning outcomes of the course").optional(),
  examFeatures: z.array(z.string()).describe("Exam features included in the course").optional(),
  curriculum: z.array(z.string()).describe("Course curriculum structure/sections").optional(),
  prerequisiteIds: z.array(z.string()).describe("IDs of prerequisite courses").optional(),
  maxStudents: z.number().describe("Maximum number of students allowed").optional(),
  isPublished: z.boolean().default(false).describe("Whether the course is published and visible to students").optional(),
  status: z.enum(["LIVE", "RECORDED"]).describe("Course status indicating whether content is live or recorded").optional(),
  isFeatured: z.boolean().default(false).describe("Whether the course is featured on the homepage").optional(),
  version: z.string().describe("Course version (e.g., 2024, 2025)").optional(),
  whatsappUrl: z.string().describe("WhatsApp group URL for enrolled students").optional()
});

export const LessonPreviewDtoSchema = z.object({
  id: z.string().describe("Unique lesson identifier"),
  title: z.string().describe("Lesson title"),
  description: z.string().describe("Lesson description").nullable(),
  duration: z.number().describe("Duration in minutes").nullable(),
  order: z.number().describe("Display order"),
  isFree: z.boolean().describe("Is free to access")
});

export const CourseResponseDtoSchema = z.object({
  id: z.string().describe("Unique course identifier"),
  title: z.string().describe("Course title"),
  slug: z.string().describe("URL-friendly slug"),
  description: z.string().describe("Course description"),
  thumbnail: z.string().describe("Course thumbnail URL").nullable(),
  language: z.string().describe("Course language"),
  langDescription: z.string().describe("Additional description for international students").optional(),
  internationalExamLang: z.enum(["en", "ar", "en_ar"]).describe("Preferred exam language for international students").optional(),
  status: z.enum(["LIVE", "RECORDED"]).describe("Course status (LIVE or RECORDED)"),
  certificateName: z.string().describe("Name of the certificate awarded upon completion (if any)").nullable(),
  version: z.string().describe("Course version (e.g., 2024, 2025)"),
  price: z.number().describe("Course price in USD or EGP depending on user location"),
  priceUSD: z.number().describe("Course price in USD (for admin)").optional(),
  priceEGP: z.number().describe("Course price in EGP (for admin)").optional(),
  currency: z.enum(["USD", "EGP"]).describe("Currency of the price (USD or EGP)"),
  duration: z.number().describe("Course duration in hours").nullable(),
  isPublished: z.boolean().describe("Whether course is published"),
  isFeatured: z.boolean().describe("Whether course is featured"),
  enrollmentCount: z.number().describe("Number of enrolled students"),
  averageRating: z.record(z.unknown()).describe("Average rating").nullable(),
  reviewCount: z.number().describe("Number of reviews"),
  maxStudents: z.number().describe("Maximum number of students allowed").nullable(),
  targetAudience: z.array(z.string()).describe("Target audience for the course").optional(),
  learningOutcomes: z.array(z.string()).describe("Learning outcomes of the course").optional(),
  examFeatures: z.array(z.string()).describe("Exam features included in the course").optional(),
  curriculum: z.array(z.string()).describe("Course curriculum structure/sections").optional(),
  lectures: z.array(z.lazy(() => LessonPreviewDtoSchema)).describe("Lesson previews (titles and metadata only, no URLs)").optional(),
  createdAt: z.string().describe("Course creation timestamp"),
  updatedAt: z.string().describe("Last update timestamp"),
  progress: z.number().describe("Progress percentage (for enrolled courses)").optional(),
  whatsappUrl: z.string().describe("WhatsApp group URL for enrolled students").optional(),
  paymentMethods: z.array(z.enum(["ONLINE", "MANUAL"])).describe("Payment methods supported by the course").optional()
});

export const PaginationMetaDtoSchema = z.object({
  total: z.number().describe("Total number of items"),
  page: z.number().describe("Current page number"),
  limit: z.number().describe("Number of items per page"),
  totalPages: z.number().describe("Total number of pages")
});

export const CourseListResponseDtoSchema = z.object({
  data: z.array(z.lazy(() => CourseResponseDtoSchema)).describe("List of courses"),
  meta: z.lazy(() => PaginationMetaDtoSchema)
});

export const UpdateCourseDtoSchema = z.object({
  title: z.string().min(2).describe("Course title").optional(),
  description: z.string().min(10).describe("Detailed course description").optional(),
  thumbnail: z.string().describe("Course thumbnail image URL").optional(),
  certificateName: z.string().describe("Course's certificate display name").optional(),
  language: z.string().describe("Course language").optional(),
  langDescription: z.string().describe("Additional description in course language for international users").optional(),
  internationalExamLang: z.enum(["en", "ar", "en_ar"]).describe("Preferred exam language for international students").optional(),
  priceUSD: z.number().gte(0).describe("Course price in USD").optional(),
  priceEGP: z.number().gte(0).describe("Course price in EGP (Egyptian Pound)").optional(),
  isPublished: z.boolean().describe("Whether the course is published and visible to students").optional(),
  status: z.enum(["LIVE", "RECORDED"]).describe("Course status indicating whether content is live or recorded").optional(),
  isFeatured: z.boolean().describe("Whether the course is featured on the homepage").optional(),
  version: z.string().describe("Course version (e.g., 2024, 2025)").optional(),
  categoryId: z.string().describe("Category ID").optional(),
  tags: z.array(z.string()).describe("Course tags").optional(),
  targetAudience: z.array(z.string()).describe("Target audience for the course").optional(),
  learningOutcomes: z.array(z.string()).describe("Learning outcomes of the course").optional(),
  examFeatures: z.array(z.string()).describe("Exam features included in the course").optional(),
  curriculum: z.array(z.string()).describe("Course curriculum structure/sections").optional(),
  prerequisiteIds: z.array(z.string()).describe("IDs of prerequisite courses").optional(),
  maxStudents: z.number().describe("Maximum number of students allowed").optional(),
  whatsappUrl: z.string().describe("WhatsApp group URL for enrolled students").optional(),
  paymentMethods: z.array(z.enum(["ONLINE", "MANUAL"])).describe("Payment methods supported by the course").optional()
});

export const EnrollCourseDtoSchema = z.object({
  courseId: z.string().describe("Course ID to enroll in"),
  packageId: z.string().describe("Package ID if enrolling via package").optional(),
  enrollmentType: z.enum(["FULL_COURSE", "QUIZZES_ONLY"]).default("FULL_COURSE").describe("Type of enrollment (full course or quizzes only)").optional()
});

export const EnrollmentResponseDtoSchema = z.object({
  id: z.string().describe("Enrollment ID"),
  course: z.lazy(() => CourseResponseDtoSchema),
  currency: z.enum(["USD", "EGP"]).describe("Currency of the course price (USD or EGP)"),
  status: z.enum(["ACTIVE", "SUSPENDED", "COMPLETED", "CANCELLED"]).describe("Enrollment status"),
  enrollmentType: z.enum(["FULL_COURSE", "QUIZZES_ONLY"]).describe("Type of enrollment"),
  progress: z.number().describe("Current progress percentage"),
  enrolledAt: z.string().describe("Enrollment date"),
  lastAccessedAt: z.string().describe("Last activity timestamp")
});

export const SuccessResponseDtoSchema = z.object({
  success: z.boolean().describe("Success status"),
  message: z.string().describe("Response message")
});

export const RateCourseDtoSchema = z.object({
  rating: z.number().gte(1).lte(5).describe("Rating from 1 to 5 stars"),
  title: z.string().describe("Review title").optional(),
  comment: z.string().describe("Detailed review comment").optional()
});

export const CourseReviewResponseDtoSchema = z.object({
  id: z.string().describe("Review ID"),
  courseId: z.string().describe("Course ID"),
  userId: z.string().describe("User ID who wrote the review"),
  rating: z.number().describe("Rating (1-5)"),
  comment: z.record(z.unknown()).describe("Review comment").nullable(),
  createdAt: z.string().describe("Review creation timestamp"),
  updatedAt: z.string().describe("Last update timestamp"),
  user: z.record(z.unknown()).describe("User who wrote the review")
});

export const UpdateCourseReviewDtoSchema = z.object({
  rating: z.number().gte(1).lte(5).describe("Rating from 1 to 5 stars").optional(),
  title: z.string().describe("Review title").optional(),
  comment: z.string().describe("Detailed review comment").optional(),
  isVisible: z.boolean().describe("Whether the review is visible to other users").optional()
});

export const CourseStatsResponseDtoSchema = z.object({
  totalStudents: z.number().describe("Total enrolled students"),
  activeStudents: z.number().describe("Active students (accessed in last 30 days)"),
  completedStudents: z.number().describe("Students who completed the course"),
  averageProgress: z.number().describe("Average course completion percentage"),
  averageRating: z.number().describe("Average rating"),
  totalRevenue: z.number().describe("Total revenue generated"),
  enrollmentTrend: z.record(z.unknown()).describe("Enrollment trend (last 30 days)")
});

export const AdminCoursesResponseDtoSchema = z.object({
  data: z.array(z.lazy(() => CourseResponseDtoSchema)).describe("List of admin courses"),
  meta: z.lazy(() => PaginationMetaDtoSchema)
});

export const CourseStudentDtoSchema = z.object({
  id: z.string().describe("User ID"),
  email: z.string().describe("Student email"),
  name: z.record(z.unknown()).describe("Student name").nullable(),
  avatar: z.record(z.unknown()).describe("Student avatar URL").nullable(),
  enrollmentId: z.string().describe("Enrollment ID"),
  status: z.enum(["ACTIVE", "SUSPENDED", "COMPLETED", "CANCELLED"]).describe("Enrollment status"),
  enrolledAt: z.string().describe("Enrollment date")
});

export const CourseStudentsResponseDtoSchema = z.object({
  students: z.array(z.lazy(() => CourseStudentDtoSchema)).describe("List of enrolled students"),
  pagination: z.lazy(() => PaginationMetaDtoSchema)
});

export const EnrollmentUserDtoSchema = z.object({
  id: z.string(),
  name: z.string(),
  email: z.string(),
  avatar: z.record(z.unknown()).optional(),
  phone: z.record(z.unknown()).optional()
});

export const EnrollmentCourseDtoSchema = z.object({
  id: z.string(),
  title: z.string(),
  slug: z.string(),
  thumbnail: z.record(z.unknown()).optional(),
  version: z.record(z.unknown()).optional()
});

export const EnrollmentPackageDtoSchema = z.object({
  id: z.string(),
  name: z.string(),
  slug: z.string()
});

export const EnrollmentItemDtoSchema = z.object({
  id: z.string(),
  userId: z.record(z.unknown()),
  courseId: z.record(z.unknown()),
  packageId: z.record(z.unknown()).optional(),
  itemName: z.string(),
  status: z.enum(["ACTIVE", "SUSPENDED", "COMPLETED", "CANCELLED", "PENDING"]),
  enrolledAt: z.string(),
  updatedAt: z.string().optional(),
  user: z.lazy(() => EnrollmentUserDtoSchema).optional(),
  course: z.lazy(() => EnrollmentCourseDtoSchema).optional(),
  package: z.lazy(() => EnrollmentPackageDtoSchema).optional()
});

export const PaginationDtoSchema = z.object({
  total: z.number().describe("Total number of items"),
  page: z.number().describe("Current page number"),
  limit: z.number().describe("Items per page"),
  totalPages: z.number().describe("Total number of pages")
});

export const GetAllEnrollmentsResponseDtoSchema = z.object({
  enrollments: z.array(z.lazy(() => EnrollmentItemDtoSchema)),
  pagination: z.lazy(() => PaginationDtoSchema)
});

export const EnrollmentStatisticsResponseDtoSchema = z.object({
  totalEnrollments: z.number().describe("Total number of enrollments"),
  activeEnrollments: z.number().describe("Number of active enrollments"),
  suspendedEnrollments: z.number().describe("Number of suspended enrollments"),
  completedEnrollments: z.number().describe("Number of completed enrollments"),
  cancelledEnrollments: z.number().describe("Number of cancelled enrollments"),
  enrollmentsByMonth: z.number().describe("Number of enrollment groups by month"),
  topCourses: z.number().describe("Number of top courses")
});

export const EnrollmentCourseDetailDtoSchema = z.object({
  id: z.string(),
  title: z.string(),
  slug: z.string(),
  thumbnail: z.record(z.unknown()).nullable().optional(),
  _count: z.object({
  lectures: z.number().optional()
})
});

export const EnrollmentPackageDetailDtoSchema = z.object({
  id: z.string(),
  name: z.string(),
  slug: z.string(),
  status: z.string().optional()
});

export const EnrollmentPaymentDtoSchema = z.object({
  id: z.string(),
  status: z.string(),
  createdAt: z.string()
});

export const GetEnrollmentByIdResponseDtoSchema = z.object({
  id: z.string(),
  userId: z.record(z.unknown()),
  courseId: z.record(z.unknown()),
  packageId: z.record(z.unknown()).optional(),
  itemName: z.string(),
  status: z.enum(["ACTIVE", "SUSPENDED", "COMPLETED", "CANCELLED", "PENDING"]),
  enrolledAt: z.string(),
  updatedAt: z.string().optional(),
  user: z.lazy(() => EnrollmentUserDtoSchema).optional(),
  course: z.lazy(() => EnrollmentCourseDetailDtoSchema).optional(),
  package: z.lazy(() => EnrollmentPackageDetailDtoSchema).optional(),
  payments: z.array(z.lazy(() => EnrollmentPaymentDtoSchema)).optional()
});

export const UpdateEnrollmentStatusDtoSchema = z.object({
  status: z.enum(["ACTIVE", "SUSPENDED", "COMPLETED", "CANCELLED", "PENDING"]).describe("New enrollment status"),
  reason: z.string().describe("Reason for status change").optional()
});

export const UpdateEnrollmentUserDtoSchema = z.object({
  id: z.string(),
  name: z.string(),
  email: z.string()
});

export const UpdateEnrollmentCourseDtoSchema = z.object({
  id: z.string(),
  title: z.string()
});

export const UpdateEnrollmentStatusResponseDtoSchema = z.object({
  id: z.string(),
  userId: z.record(z.unknown()),
  courseId: z.record(z.unknown()),
  status: z.enum(["ACTIVE", "SUSPENDED", "COMPLETED", "CANCELLED", "PENDING"]),
  enrolledAt: z.string(),
  updatedAt: z.string().optional(),
  user: z.lazy(() => UpdateEnrollmentUserDtoSchema).optional(),
  course: z.lazy(() => UpdateEnrollmentCourseDtoSchema).optional()
});

export const WithdrawEnrollmentCourseDtoSchema = z.object({
  id: z.string(),
  title: z.string()
});

export const WithdrawEnrollmentResponseDtoSchema = z.object({
  id: z.string(),
  userId: z.record(z.unknown()),
  courseId: z.record(z.unknown()),
  status: z.enum(["ACTIVE", "SUSPENDED", "COMPLETED", "CANCELLED", "PENDING"]),
  enrolledAt: z.string(),
  updatedAt: z.string().optional(),
  course: z.lazy(() => WithdrawEnrollmentCourseDtoSchema).optional()
});

export const EnrollmentProgressDtoSchema = z.object({
  progress: z.number().describe("Progress percentage (0-100)").optional(),
  lastAccessedLessonId: z.string().describe("Last accessed lesson ID").optional()
});

export const UpdateProgressResponseDtoSchema = z.object({
  message: z.string(),
  enrollmentId: z.string(),
  progress: z.number().optional(),
  lastAccessedLessonId: z.string().optional()
});

export const BulkEnrollDtoSchema = z.object({
  userIds: z.array(z.string()).describe("Array of user IDs to enroll"),
  courseIds: z.array(z.string()).describe("Array of course IDs to enroll users in (either courseIds or packageIds required)").optional(),
  packageIds: z.array(z.string()).describe("Array of package IDs to enroll users in (either courseIds or packageIds required)").optional(),
  enrollmentType: z.enum(["FULL_COURSE", "QUIZZES_ONLY"]).default("FULL_COURSE").describe("Type of enrollment (full course or quizzes only)").optional()
});

export const BulkEnrollResultDetailsDtoSchema = z.object({
  successful: z.array(z.object({
  userId: z.string().optional(),
  courseId: z.string().nullable().optional(),
  packageId: z.string().nullable().optional()
})),
  failed: z.array(z.object({
  userId: z.string().optional(),
  courseId: z.string().nullable().optional(),
  packageId: z.string().nullable().optional(),
  reason: z.string().optional()
}))
});

export const BulkEnrollResponseDtoSchema = z.object({
  message: z.string(),
  successful: z.number().describe("Number of successful enrollments"),
  failed: z.number().describe("Number of failed enrollments"),
  details: z.lazy(() => BulkEnrollResultDetailsDtoSchema)
});

export const AdminCreateEnrollmentDtoSchema = z.object({
  userId: z.string().describe("User ID to enroll"),
  courseId: z.string().describe("Course ID to enroll user in (either courseId or packageId required)").optional(),
  packageId: z.string().describe("Package ID to enroll user in (either courseId or packageId required)").optional(),
  status: z.enum(["ACTIVE", "SUSPENDED", "COMPLETED", "CANCELLED", "PENDING"]).default("ACTIVE").describe("Initial enrollment status").optional(),
  enrollmentType: z.enum(["FULL_COURSE", "QUIZZES_ONLY"]).default("FULL_COURSE").describe("Type of enrollment (full course or quizzes only)").optional(),
  progress: z.number().default(0).describe("Initial progress (0-100)").optional()
});

export const AdminUpdateEnrollmentDtoSchema = z.object({
  status: z.enum(["ACTIVE", "SUSPENDED", "COMPLETED", "CANCELLED", "PENDING"]).describe("Enrollment status").optional(),
  enrollmentType: z.enum(["FULL_COURSE", "QUIZZES_ONLY"]).describe("Type of enrollment (full course or quizzes only)").optional(),
  progress: z.number().describe("Progress percentage (0-100)").optional()
});

export const SubmitWhatsAppPhoneDtoSchema = z.object({
  courseId: z.string().describe("Course ID for the enrollment"),
  phone: z.string().describe("Phone number for WhatsApp group access (E.164 format or international)")
});

export const SubmitWhatsAppPhoneResponseDtoSchema = z.object({
  enrollmentId: z.string(),
  phone: z.string(),
  whatsappUrl: z.record(z.unknown()).optional(),
  submittedAt: z.record(z.unknown()).optional(),
  message: z.string()
});

export const DeleteResponseDtoSchema = z.object({
  success: z.boolean().describe("Success status"),
  message: z.string().describe("Confirmation message"),
  id: z.string().describe("ID of deleted resource").optional()
});

export const CreateLectureDtoSchema = z.object({
  title: z.string().min(3).describe("Lecture title"),
  description: z.string().describe("Lecture description").optional(),
  content: z.string().describe("Lecture content in HTML or markdown format").optional(),
  videoUrl: z.string().describe("URL to lecture video").optional(),
  pdfUrl: z.string().describe("URL to lecture PDF file").optional(),
  duration: z.number().gte(0).describe("Lecture duration in seconds").optional(),
  order: z.number().gte(0).describe("Display order within the course"),
  courseId: z.string().describe("ID of the course this lecture belongs to"),
  nextLectureId: z.string().describe("ID of the next lecture in sequence (for multi-part lectures)").optional(),
  isFree: z.boolean().default(false).describe("Whether the lecture is free to access without enrollment").optional(),
  isPublished: z.boolean().default(false).describe("Whether the lecture is published and visible to students").optional()
});

export const LectureAttachmentDtoSchema = z.object({
  id: z.string().describe("Attachment ID"),
  title: z.string().describe("Attachment title"),
  fileUrl: z.string().describe("File URL"),
  fileType: z.string().describe("File type"),
  fileSize: z.number().describe("File size in bytes"),
  createdAt: z.string().describe("Creation timestamp")
});

export const LessonResponseDtoSchema = z.object({
  id: z.string().describe("Unique lesson identifier"),
  title: z.string().describe("Lesson title"),
  description: z.string().describe("Lesson description").nullable(),
  content: z.string().describe("Lesson content").nullable(),
  videoUrl: z.string().describe("Video URL"),
  pdfUrl: z.string().describe("PDF URL").nullable(),
  duration: z.number().describe("Duration in minutes").nullable(),
  order: z.number().describe("Display order"),
  courseId: z.string().describe("Course ID"),
  isFree: z.boolean().describe("Is free to access"),
  isPublished: z.boolean().describe("Is published"),
  createdAt: z.string().describe("Creation timestamp"),
  updatedAt: z.string().describe("Last update timestamp"),
  attachments: z.array(z.lazy(() => LectureAttachmentDtoSchema)).describe("List of lesson attachments")
});

export const LessonListResponseDtoSchema = z.object({
  data: z.array(z.lazy(() => LessonResponseDtoSchema)).describe("List of lessons"),
  meta: z.record(z.unknown()).describe("Pagination metadata")
});

export const UpdateLectureDtoSchema = z.object({
  title: z.string().min(3).describe("Lecture title").optional(),
  description: z.string().describe("Lecture description").optional(),
  content: z.string().describe("Lecture content in HTML or markdown format").optional(),
  videoUrl: z.string().describe("URL to lecture video").optional(),
  pdfUrl: z.string().describe("URL to lecture PDF file").optional(),
  duration: z.number().gte(0).describe("Lecture duration in seconds").optional(),
  order: z.number().gte(0).describe("Display order within the course").optional(),
  nextLectureId: z.string().describe("ID of the next lecture in sequence").optional(),
  isPublished: z.boolean().describe("Whether the lecture is published and visible to students").optional(),
  isFree: z.boolean().describe("Whether the lecture is free to access without enrollment").optional()
});

export const CreateAttachmentDtoSchema = z.object({
  name: z.string().describe("Attachment file name"),
  url: z.string().describe("URL to the attachment file"),
  fileSize: z.number().describe("File size in bytes").optional(),
  mimeType: z.string().describe("MIME type of the file").optional(),
  order: z.number().gte(0).describe("Display order for multiple attachments").optional()
});

export const UpdateProgressDtoSchema = z.object({
  progress: z.number().gte(0).lte(100).describe("Progress percentage (0-100)"),
  completed: z.boolean().describe("Whether the lesson is marked as completed").optional(),
  timeSpent: z.number().gte(0).describe("Time spent on the lesson in seconds").optional()
});

export const LectureProgressItemDtoSchema = z.object({
  lectureId: z.string().describe("Lecture ID"),
  title: z.string().describe("Lecture title"),
  order: z.number().describe("Lecture order"),
  progress: z.number().describe("Progress percentage"),
  completed: z.boolean().describe("Is completed"),
  timeSpent: z.number().describe("Time spent in seconds"),
  lastViewed: z.record(z.unknown()).describe("Last viewed timestamp").nullable()
});

export const CourseProgressResponseDtoSchema = z.object({
  totalLectures: z.number().describe("Total number of lectures in the course"),
  completedLectures: z.number().describe("Number of completed lectures"),
  overallProgress: z.number().describe("Overall progress percentage"),
  whatsappPhoneSubmitted: z.boolean().describe("Whether the user has already submitted a WhatsApp phone number for this course"),
  lectures: z.array(z.lazy(() => LectureProgressItemDtoSchema)).describe("List of lecture progress details")
});

export const StreamTokenResponseDtoSchema = z.object({
  token: z.string().describe("HMAC-SHA256 signed token"),
  expires: z.number().describe("Unix timestamp when token expires"),
  playlistUrl: z.string().describe("HLS playlist URL")
});

export const BulkCreateLecturesDtoSchema = z.object({
  lectures: z.array(z.lazy(() => CreateLectureDtoSchema)).describe("Array of lectures to create")
});

export const BulkOperationResultDtoSchema = z.object({
  index: z.number().describe("Index of the item"),
  title: z.string().describe("Title of the item"),
  reason: z.string().describe("Reason for failure")
});

export const BulkCreateDetailsDtoSchema = z.object({
  successful: z.array(z.record(z.unknown())).describe("Successfully created items"),
  failed: z.array(z.lazy(() => BulkOperationResultDtoSchema)).describe("Failed items with details")
});

export const BulkCreateResponseDtoSchema = z.object({
  message: z.string().describe("Success message"),
  successful: z.number().describe("Number of successful operations"),
  failed: z.number().describe("Number of failed operations"),
  details: z.lazy(() => BulkCreateDetailsDtoSchema)
});

export const ReorderLecturesDtoSchema = z.object({
  lectureIds: z.array(z.string()).describe("Array of lecture IDs in the desired order")
});

export const ReorderResponseDtoSchema = z.object({
  message: z.string().describe("Success message"),
  updated: z.number().describe("Number of lectures updated")
});

export const BulkDeleteLecturesDtoSchema = z.object({
  lectureIds: z.array(z.string()).describe("Array of lecture IDs to delete")
});

export const BulkDeleteResponseDtoSchema = z.object({
  message: z.string().describe("Success message"),
  deleted: z.number().describe("Number of lectures deleted")
});

export const BulkPublishLecturesDtoSchema = z.object({
  lectureIds: z.array(z.string()).describe("Array of lecture IDs to publish/unpublish"),
  isPublished: z.boolean().describe("Whether to publish (true) or unpublish (false)")
});

export const BulkPublishResponseDtoSchema = z.object({
  message: z.string().describe("Success message"),
  updated: z.number().describe("Number of lectures updated"),
  isPublished: z.boolean().describe("New publish status")
});

export const CopyLectureDtoSchema = z.object({
  targetCourseId: z.string().describe("Target course ID (if copying to different course)").optional(),
  title: z.string().describe("New title for the copied lecture").optional(),
  copyAttachments: z.boolean().default(true).describe("Whether to copy attachments as well").optional()
});

export const LectureStatisticsResponseDtoSchema = z.object({
  lectureId: z.string().describe("Lecture ID"),
  title: z.string().describe("Lecture title"),
  totalViews: z.number().describe("Total number of views"),
  completedCount: z.number().describe("Number of students who completed"),
  completionRate: z.number().describe("Completion rate percentage"),
  averageProgress: z.number().describe("Average progress percentage"),
  averageTimeSpent: z.number().describe("Average time spent in seconds")
});

export const GenerateVideoSessionDtoSchema = z.object({
  lectureId: z.string().describe("Lecture ID for enrollment verification"),
  videoUrl: z.string().describe("Video URL (optional - backend reads from lecture record if not provided)").optional(),
  ttl: z.number().default(300).describe("Session TTL in seconds (VdoCipher only)").optional(),
  annotate: z.string().describe("Watermark text for video (VdoCipher only)").optional()
});

export const VideoSessionResponseDtoSchema = z.object({
  type: z.enum(["vdocipher", "google-drive", "direct", "hls", "unknown"]).describe("Video type detected"),
  originalUrl: z.string().describe("Original video URL"),
  embedUrl: z.string().describe("Processed embed URL (ready to use)"),
  vdoCipherSession: z.record(z.unknown()).describe("VdoCipher session details (if applicable)").optional(),
  expiresAt: z.number().describe("Session expiration timestamp (Unix time)").optional()
});

export const EncryptionKeyResponseDtoSchema = z.object({
  key: z.string().describe("Binary encryption key for HLS stream decryption")
});

export const PlaylistResponseDtoSchema = z.object({
  playlist: z.string().describe("HLS playlist content in M3U8 format with signed URLs")
});

export const SegmentResponseDtoSchema = z.object({
  segment: z.string().describe("HLS video segment in MPEG-TS format")
});

export const DifficultyLevelSchema = z.enum(["BEGINNER", "INTERMEDIATE", "ADVANCED", "EXPERT"]).describe("Overall difficulty level of the quiz");

export const QuestionTranslationDtoSchema = z.object({
  language: z.enum(["en", "ar"]).describe("Language code (en, ar, etc.)"),
  text: z.string().describe("Translated question text"),
  explanation: z.string().describe("Translated explanation").optional()
});

export const QuestionTypeSchema = z.enum(["MCQ", "MULTIPLE_ANSWER", "DRAG_DROP"]).describe("Type of question");

export const OptionTranslationDtoSchema = z.object({
  language: z.enum(["en", "ar"]).describe("Language code (en, ar, etc.)"),
  text: z.string().describe("Translated option text")
});

export const QuestionOptionDtoSchema = z.object({
  translations: z.array(z.lazy(() => OptionTranslationDtoSchema)).describe("Translations for this option").optional(),
  isCorrect: z.boolean().describe("Whether this option is correct"),
  text: z.string().describe("Option text (fallback if translations not provided)").optional()
});

export const MatchTranslationDtoSchema = z.object({
  language: z.record(z.unknown()).describe("Language code (en, ar, etc.)"),
  leftText: z.string().describe("Left text for matching"),
  rightText: z.string().describe("Right text for matching")
});

export const QuestionMatchDtoSchema = z.object({
  translations: z.array(z.lazy(() => MatchTranslationDtoSchema)).describe("Translations for this match pair")
});

export const DistractorTranslationDtoSchema = z.object({
  language: z.record(z.unknown()).describe("Language code (en, ar, etc.)"),
  text: z.string().describe("Distractor text (fake draggable item)")
});

export const QuestionMatchDistractorDtoSchema = z.object({
  translations: z.array(z.lazy(() => DistractorTranslationDtoSchema)).describe("Translations for this distractor item")
});

export const CreateQuestionDtoSchema = z.object({
  question: z.string().describe("The question text"),
  translations: z.array(z.lazy(() => QuestionTranslationDtoSchema)).describe("Translations for question text and explanation").optional(),
  type: z.lazy(() => QuestionTypeSchema),
  options: z.array(z.lazy(() => QuestionOptionDtoSchema)).describe("Question options (for MCQ, MULTIPLE_ANSWER)").optional(),
  matches: z.array(z.lazy(() => QuestionMatchDtoSchema)).describe("Match pairs for DRAG_DROP questions").optional(),
  distractors: z.array(z.lazy(() => QuestionMatchDistractorDtoSchema)).describe("Distractor items for DRAG_DROP questions (extra wrong draggable items)").optional(),
  correctAnswer: z.record(z.unknown()).describe("Correct answer(s) for the question").optional(),
  explanation: z.string().describe("Explanation shown after answering").optional(),
  marks: z.number().gte(1).describe("Points awarded for correct answer").optional(),
  order: z.number().gte(0).describe("Display order of question in quiz").optional(),
  difficulty: z.lazy(() => DifficultyLevelSchema).optional(),
  hints: z.record(z.unknown()).describe("Hints to help answer the question").optional(),
  maxAttempts: z.number().gte(1).describe("Maximum attempts allowed for this question").optional(),
  partialCredit: z.boolean().describe("Whether to award partial credit for partially correct answers").optional(),
  tags: z.array(z.string()).describe("Tags for categorizing the question").optional(),
  imageUrl: z.string().describe("URL of an image to display with the question").optional(),
  isActive: z.boolean().default(true).describe("Whether this question is active and visible in quizzes").optional()
});

export const CreateQuizDtoSchema = z.object({
  courseIds: z.array(z.string()).describe("IDs of the courses this quiz belongs to (optional)").optional(),
  groupIds: z.array(z.string()).describe("IDs of the courses groups this quiz belongs to (optional)").optional(),
  lectureIds: z.array(z.string()).describe("IDs of lectures this quiz belongs to (optional, can be multiple)").optional(),
  title: z.string().describe("Quiz title"),
  description: z.string().describe("Quiz description").optional(),
  language: z.enum(["en", "ar", "en_ar"]).default("en").describe("Quiz language (en, ar, or en_ar for bilingual)").optional(),
  type: z.enum(["quiz", "full_exam"]).default("quiz").describe("Quiz type (quiz for short tests, full_exam for comprehensive exams)").optional(),
  totalMarks: z.number().gte(1).describe("Total marks for the quiz"),
  passingScore: z.number().gte(0).lte(100).describe("Passing score percentage (0-100)").optional(),
  timeLimit: z.number().gte(1).describe("Time limit in minutes").optional(),
  attemptsLimit: z.number().gte(1).default(4).describe("Maximum number of attempts allowed (default: 4)").optional(),
  difficulty: z.lazy(() => DifficultyLevelSchema).optional(),
  showCorrectness: z.boolean().describe("Whether to show correctness immediately after answering").optional(),
  showExplanation: z.boolean().describe("Whether to show explanations after answering").optional(),
  shuffleQuestions: z.boolean().describe("Whether to randomize question order").optional(),
  shuffleOptions: z.boolean().describe("Whether to randomize option order (for MCQ)").optional(),
  isPublished: z.boolean().describe("Whether the quiz is published and available to students").optional(),
  questions: z.array(z.lazy(() => CreateQuestionDtoSchema)).describe("Array of questions to create with the quiz").optional()
});

export const QuestionTranslationResponseDtoSchema = z.object({
  id: z.string().describe("Translation ID"),
  language: z.enum(["en", "ar"]).describe("Language code"),
  text: z.string().describe("Translated question text"),
  explanation: z.record(z.unknown()).describe("Translated explanation").nullable()
});

export const OptionTranslationResponseDtoSchema = z.object({
  id: z.string().describe("Translation ID"),
  language: z.enum(["en", "ar"]).describe("Language code"),
  text: z.string().describe("Translated option text")
});

export const QuizQuestionOptionDtoSchema = z.object({
  id: z.string().describe("Option ID"),
  questionId: z.string().describe("Question ID (FK)").optional(),
  order: z.number().describe("Display order"),
  isCorrect: z.boolean().describe("Whether this option is the correct answer").optional(),
  translations: z.array(z.lazy(() => OptionTranslationResponseDtoSchema)).describe("Option translations")
});

export const MatchTranslationResponseDtoSchema = z.object({
  id: z.string().describe("Translation ID"),
  language: z.enum(["en", "ar"]).describe("Language code"),
  leftText: z.string().describe("Translated left side text"),
  rightText: z.string().describe("Translated right side text")
});

export const QuizQuestionMatchDtoSchema = z.object({
  id: z.string().describe("Match ID"),
  questionId: z.string().describe("Question ID (FK)").optional(),
  translations: z.array(z.lazy(() => MatchTranslationResponseDtoSchema)).describe("Match translations")
});

export const DistractorTranslationResponseDtoSchema = z.object({
  id: z.string().describe("Translation ID"),
  language: z.string().describe("Language code"),
  text: z.string().describe("Distractor text")
});

export const QuizQuestionDistractorDtoSchema = z.object({
  id: z.string().describe("Distractor ID"),
  questionId: z.string().describe("Question ID (FK)").optional(),
  order: z.number().describe("Display order").optional(),
  translations: z.array(z.lazy(() => DistractorTranslationResponseDtoSchema)).describe("Distractor translations")
});

export const QuizQuestionDetailDtoSchema = z.object({
  id: z.string().describe("Question ID"),
  quizId: z.number().describe("Quiz ID").optional(),
  type: z.lazy(() => QuestionTypeSchema),
  marks: z.number().describe("Points awarded for correct answer"),
  order: z.number().describe("Display order"),
  difficulty: z.enum(["BEGINNER", "INTERMEDIATE", "ADVANCED", "EXPERT"]).describe("Difficulty level").nullable().optional(),
  partialCredit: z.boolean().describe("Whether partial credit is awarded").optional(),
  codeLanguage: z.record(z.unknown()).describe("Programming language for code questions").nullable().optional(),
  isActive: z.boolean().describe("Whether the question is active").optional(),
  language: z.enum(["en", "ar"]).describe("Question language").optional(),
  imageUrl: z.record(z.unknown()).describe("Image URL for the question").nullable().optional(),
  createdAt: z.string().describe("Created at").optional(),
  updatedAt: z.string().describe("Updated at").optional(),
  translations: z.array(z.lazy(() => QuestionTranslationResponseDtoSchema)).describe("Question text translations"),
  optionsList: z.array(z.lazy(() => QuizQuestionOptionDtoSchema)).describe("Answer options with translations"),
  matches: z.array(z.lazy(() => QuizQuestionMatchDtoSchema)).describe("Match pairs with translations (for DRAG_DROP)"),
  distractors: z.array(z.lazy(() => QuizQuestionDistractorDtoSchema)).describe("Distractor items with translations (for DRAG_DROP)").optional(),
  expectedCorrectCount: z.number().describe("Expected number of correct answers (for MULTIPLE_ANSWER)").optional()
});

export const QuizCourseInfoSchema = z.object({
  id: z.string().describe("Course ID"),
  title: z.string().describe("Course title")
});

export const AttemptsInfoSchema = z.object({
  used: z.number().describe("Number of attempts used/completed"),
  limit: z.number().describe("Total allowed attempts including extras").nullable(),
  remaining: z.number().describe("Remaining attempts").nullable(),
  extraAllowed: z.number().default(0).describe("Extra attempts granted by admin"),
  isPracticeMode: z.boolean().default(false).describe("Is this a practice mode quiz")
});

export const QuizDataSchema = z.object({
  id: z.number().describe("Quiz ID"),
  courseIds: z.array(z.string()).describe("Course IDs (many-to-many)"),
  groupIds: z.array(z.string()).describe("Group IDs (many-to-many)").optional(),
  lectureIds: z.array(z.string()).describe("Lecture IDs (many-to-many)").optional(),
  title: z.string().describe("Quiz title"),
  description: z.string().describe("Quiz description").optional(),
  language: z.enum(["en", "ar", "en_ar"]).default("en").describe("Quiz language"),
  type: z.enum(["quiz", "full_exam"]).default("quiz").describe("Quiz type"),
  totalMarks: z.number().describe("Total marks"),
  passingScore: z.number().describe("Passing score"),
  timeLimit: z.number().describe("Time limit in minutes").optional(),
  attemptsLimit: z.number().default(4).describe("Number of allowed attempts including extras"),
  difficulty: z.enum(["BEGINNER", "INTERMEDIATE", "ADVANCED", "EXPERT"]).describe("Difficulty level").optional(),
  showCorrectness: z.boolean().describe("Show correctness after attempt"),
  showExplanation: z.boolean().describe("Show explanation after attempt"),
  shuffleQuestions: z.boolean().describe("Shuffle questions order"),
  shuffleOptions: z.boolean().describe("Shuffle options order"),
  isPublished: z.boolean().describe("Is quiz published"),
  questionsCount: z.number().describe("Number of questions in quiz").optional(),
  questions: z.array(z.lazy(() => QuizQuestionDetailDtoSchema)).describe("Quiz questions with full details").optional(),
  createdAt: z.string().describe("Created at"),
  updatedAt: z.string().describe("Updated at"),
  deletedAt: z.string().describe("Deleted at").optional(),
  course: z.lazy(() => QuizCourseInfoSchema).optional(),
  groups: z.array(z.object({
  id: z.string().optional(),
  name: z.string().optional()
})).describe("Groups information").optional(),
  courses: z.array(z.object({
  id: z.string().optional(),
  title: z.string().optional()
})).describe("Courses information").optional(),
  lectures: z.array(z.object({
  id: z.string().optional(),
  title: z.string().optional(),
  order: z.number().optional()
})).describe("Lectures information").optional(),
  attemptsInfo: z.lazy(() => AttemptsInfoSchema).optional(),
  _count: z.record(z.unknown()).describe("Question count from _count relation").optional(),
  canStartNewAttempt: z.boolean().describe("Can user start a new attempt").optional(),
  userAttemptCount: z.number().describe("User attempt count").optional(),
  lastAttempt: z.record(z.unknown()).describe("Last attempt by user").optional(),
  remainingAttempts: z.number().describe("Remaining attempts for user").optional()
});

