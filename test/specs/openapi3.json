{
	"openapi": "3.0.3",
	"info": {
		"title": "Test API",
		"version": "1.0.0"
	},
	"servers": [{ "url": "https://api.example.com/v1" }],
	"paths": {
		"/users/{id}": {
			"get": {
				"operationId": "getUser",
				"parameters": [
					{
						"name": "id",
						"in": "path",
						"required": true,
						"schema": { "type": "string" }
					}
				],
				"requestBody": {
					"content": {
						"application/json": {
							"schema": {
								"type": "object",
								"properties": {
									"includePosts": { "type": "boolean" }
								}
							}
						}
					}
				},
				"responses": {
					"200": {
						"description": "OK",
						"content": {
							"application/json": {
								"schema": { "$ref": "#/components/schemas/User" }
							}
						}
					},
					"400": {
						"description": "Bad request",
						"content": {
							"application/json": {
								"schema": {
									"type": "object",
									"properties": {
										"error": { "type": "string" }
									}
								}
							}
						}
					}
				}
			}
		}
	},
	"components": {
		"schemas": {
			"User": {
				"type": "object",
				"required": ["id"],
				"properties": {
					"id": { "type": "string" },
					"name": { "type": "string", "nullable": true }
				}
			}
		}
	}
}
