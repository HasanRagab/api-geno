  "paths": {
    "/auth/google": {
      "get": {
        "operationId": "googleOAuth",
        "tags": [
          "OAuth"
        ],
        "summary": "Initiate / callback for Google OAuth",
        "description": "**Two roles in one route:**\n\n1. **Initiation** – Redirects the browser to Google's consent screen.\n2. **Callback** – Google returns `?code=...`. The handler upserts the user,\n   links the OAuth account, signs a JWT, sets an HttpOnly session cookie,\n   then redirects to `redirectTo` (if valid) or the configured frontend origin.\n\n### `redirectTo` query parameter\nPass an absolute URL on the **same frontend origin** before initiating the flow.\nIt is stored in a short-lived cookie and honoured after the callback.",
        "security": [],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uri",
              "description": "Absolute URL (same frontend origin) to redirect after login.",
              "example": "http://localhost:5173"
            },
            "required": false,
            "description": "Absolute URL (same frontend origin) to redirect after login.",
            "name": "redirectTo",
            "in": "query"
          }
        ],
        "responses": {
          "302": {
            "description": "**Initiation** – redirect to Google. **Callback** – redirect to frontend after login.",
            "headers": {
              "Location": {
                "schema": {
                  "type": "string",
                  "format": "uri"
                },
                "required": true
              },
              "Set-Cookie": {
                "schema": {
                  "type": "string",
                  "description": "HttpOnly JWT session cookie (set on callback leg only)."
                },
                "required": false,
                "description": "HttpOnly JWT session cookie (set on callback leg only)."
              }
            }
          },
          "401": {
            "description": "Google did not return an email address.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Google auth feature flag is disabled on this deployment.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Unexpected error during user sync or token signing.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/auth/me": {
      "get": {
        "operationId": "getMe",
        "tags": [
          "Session"
        ],
        "summary": "Get the currently authenticated user",
        "description": "Reads the JWT from the session cookie, validates it (via upstream middleware), and returns the corresponding user record from the database.",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Authenticated user data.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid session cookie / JWT.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "JWT is valid but the user row no longer exists in the database.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "operationId": "logout",
        "tags": [
          "Session"
        ],
        "summary": "Log out the current user",
        "description": "Clears the session cookie (`path=/`). The client should discard any locally cached user state after calling this.",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Cookie cleared; user is now logged out.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          }
        }
      }
    }
