        "required": [
          "user"
        ]
      },
      "UserPayload": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "example": "3f2504e0-4f89-11d3-9a0c-0305e82c3301"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "user@example.com"
          },
          "name": {
            "type": "string",
