          },
          "avatar": {
            "type": "string",
            "format": "uri",
            "example": "https://lh3.googleusercontent.com/photo.jpg"
          }
        },
        "required": [
          "id",
          "email",
          "name",
          "avatar"
        ]
      },
      "SuccessResponse": {
        "type": "object",
