{
	"name": "api-geno",
	"version": "0.0.15",
	"type": "module",
	"module": "dist/index.js",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"private": false,
	"bin": {
		"api-geno": "dist/cli.js"
	},
	"files": [
		"dist",
		"README.md"
	],
	"description": "TypeScript OpenAPI-based API client generator with zod validation and neverthrow results.",
	"repository": {
		"type": "git",
		"url": "https://github.com/HasanRagab/api-geno.git"
	},
	"bugs": {
		"url": "https://github.com/HasanRagab/api-geno/issues"
	},
	"homepage": "https://github.com/HasanRagab/api-geno#readme",
	"scripts": {
		"clean": "rm -rf release",
		"build": "tsc && tsc-esm-fix",
		"gen": "tsc && tsc-esm-fix && bun run ./dist/cli.js generate -i api.json -o ./generated --force",
		"check": "tsc --noEmit",
		"release": "bun build src/cli.ts --outfile release/api-geno --compress --minify --target node",
		"prepublishOnly": "bun run clean && bun run build &&  bun run release"
	},
	"dependencies": {
		"axios": "^1.13.6",
		"commander": "^14.0.3",
		"neverthrow": "^8.2.0",
		"zod": "^4.3.6"
	},
	"peerDependencies": {
		"typescript": "^6.0.2"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.8",
		"@types/bun": "^1.3.11",
		"@types/node": "^25.5.0",
		"tsc-esm-fix": "^3.1.2",
		"ts-node": "^10.9.2",
		"ts-node-dev": "^2.0.0"
	},
	"engines": {
		"node": ">=18"
	},
	"author": {
		"name": "Hasan Ragab",
		"email": "hasanmragab@gmail.com",
		"url": "https://github.com/HasanRagab"
	},
	"keywords": [
		"api",
		"generator",
		"typescript",
		"cli"
	],
	"license": "MIT"
}
